{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "draftspace-collaboration",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "durable_objects": {
    "bindings": [{ "name": "ROOMS", "class_name": "Room" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["Room"] }],
  "vars": {
    "ALLOWED_ORIGINS": "http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3107,http://127.0.0.1:3110,http://127.0.0.1:3125,http://localhost:3125",
    "ROOM_GRACE_PERIOD_MS": "60000",
    "ROOM_UNCLAIMED_TTL_MS": "300000",
    "ROOM_MAX_PARTICIPANTS": "4",
    "ROOM_MAX_MESSAGE_BYTES": "5242880"
  }
}
